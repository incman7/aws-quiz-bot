# Required
PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here
VERIFY_TOKEN=aws-quiz-verify-token   # Can be any string you choose

# Groq free LLM API
GROQ_API_KEY=your_groq_api_key_here

# Optional: PostgreSQL (auto-set by Render when using render.yaml)
DATABASE_URL=

# Optional: protect the /api/send-daily endpoint from unauthorised calls
CRON_SECRET=some-random-secret-string
